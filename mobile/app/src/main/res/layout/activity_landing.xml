<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hero_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════ NAVBAR ══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/logo"
                    android:contentDescription="logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ClinicaFlow"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#190051"
                    android:paddingStart="6dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavLogin"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Log in"
                android:textSize="11sp"
                android:textColor="#190051"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="6dp"
                app:cornerRadius="10dp"
                app:strokeColor="#190051"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@android:color/transparent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavGetStarted"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Get Started"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:cornerRadius="10dp"
                app:backgroundTint="#190051" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════
             HERO — horizontal: LEFT text | RIGHT doctor card
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:baselineAligned="false"
            android:weightSum="2">

            <!-- ── LEFT COLUMN: badge + headline + desc + button ── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingEnd="8dp">

                <!-- Badge pill -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_badge_pill"
                    android:paddingStart="6dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/logo"
                        android:contentDescription="logo"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Modern Healthcare&#10;Management"
                        android:textSize="9sp"
                        android:textColor="#5b21b6"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.2" />

                </LinearLayout>

                <!-- Headline -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Streamline Your Clinic Operations"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#190051"
                    android:lineSpacingMultiplier="1.15"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="sans-serif-black" />

                <!-- Description -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A complete web-based system for small clinics and barangay health centers. Manage patient registration, queues, and consultations in a fast, organized, and digital way."
                    android:textSize="11sp"
                    android:textColor="#4a4060"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="16dp" />

                <!-- Sign In button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHeroSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:text="Sign in  →"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/bg_gradient_button"
                    app:cornerRadius="23dp" />

            </LinearLayout>
            <!-- ── RIGHT COLUMN: Modern Floating Doctor Card ── -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="260dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_gravity="center"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Main Rounded Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2A0565">

                    <!-- Soft Gradient Overlay -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_doctor_card_gradient"/>

                </com.google.android.material.card.MaterialCardView>

                <!-- Doctor Image -->
                <ImageView
                    android:id="@+id/ivHeroDoctor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/doctor"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:translationY="-5dp"
                    android:elevation="5dp"
                    android:contentDescription="Doctor" />

                <!-- Floating Card LEFT -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="92dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|top"
                    android:layout_marginTop="52dp"
                    android:layout_marginStart="3dp"
                    android:elevation="12dp"
                    android:translationZ="12dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#F5F1FA">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Our system simplifies patient registration"
                        android:textSize="5sp"
                        android:textColor="#5B4B7A"
                        android:textStyle="bold"
                        android:padding="6dp"
                        android:lineSpacingMultiplier="1.1" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Floating Card RIGHT -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="92dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="6dp"
                    android:layout_marginTop="12dp"
                    android:elevation="12dp"
                    android:translationZ="12dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#F5F1FA">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Making daily operations smoother for staff"
                        android:textSize="5sp"
                        android:textColor="#5B4B7A"
                        android:textStyle="bold"
                        android:padding="6dp"
                        android:lineSpacingMultiplier="1.1" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Bottom Floating Message -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="3dp"
                    android:elevation="20dp"
                    android:translationZ="20dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="#FFFDFD">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="We are dedicated to helping clinics operate more efficiently"
                        android:textSize="4.8sp"
                        android:textColor="#7A6D90"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:lineSpacingMultiplier="1.1" />

                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

        </LinearLayout>

        <!-- ══════════════ WHY CLINICAFLOW ══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="28dp"
            android:paddingBottom="28dp"
            android:layout_marginTop="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#f3f4f6"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Mini logo -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/logo"
                            android:contentDescription="logo"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ClinicaFlow"
                            android:textSize="10sp"
                            android:textColor="#9ca3af" />

                    </LinearLayout>

                    <!-- Two-column: text LEFT, hospital image RIGHT -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ABOUT US"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:textColor="#190051"
                                android:letterSpacing="0.12"
                                android:alpha="0.5"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Why&#10;ClinicaFlow?"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#190051"
                                android:lineSpacingMultiplier="1.1"
                                android:layout_marginBottom="8dp"
                                android:fontFamily="sans-serif-black" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="We are dedicated to helping clinics operate more efficiently through modern, streamlined digital tools. Our system simplifies patient registration, queue management, and consultation tracking."
                                android:textSize="10sp"
                                android:textColor="#6b6080"
                                android:lineSpacingMultiplier="1.55"
                                android:layout_marginBottom="12dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:layout_marginEnd="14dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="500+"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="#190051"
                                        android:fontFamily="sans-serif-black" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Clinics Served"
                                        android:textSize="9sp"
                                        android:textColor="#9b90b0" />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="98%"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="#190051"
                                        android:fontFamily="sans-serif-black" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Satisfaction"
                                        android:textSize="9sp"
                                        android:textColor="#9b90b0" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Hospital image fills right half -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#edeaf5">

                            <ImageView
                                android:id="@+id/ivHospital"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:minHeight="150dp"
                                android:src="@drawable/hospital"
                                android:scaleType="centerCrop"
                                android:contentDescription="Hospital" />

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ══════════════ CTA SECTION - Skip the Line ══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#190051"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="56dp"
            android:gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Skip the Line. Join Us Online"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:lineSpacingMultiplier="1.2"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Register yourself in the patient queue from the comfort of your home. No need to wait at the clinic — we'll notify you when it's your turn."
                android:textSize="11sp"
                android:textColor="#c4b5fd"
                android:gravity="center"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinQueue"
                android:layout_width="260dp"
                android:layout_height="52dp"
                android:text="Join Queue Now"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#190051"
                android:layout_marginBottom="12dp"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You'll receive a queue number immediately after registration"
                android:textSize="11sp"
                android:textColor="#9b90b0"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>