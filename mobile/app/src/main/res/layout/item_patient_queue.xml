<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <!-- Patient Name Column (weight 1.8 to match header) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.8"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1e293b"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvPatientId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#6b7280"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Age Column (width 45dp to match header) -->
    <TextView
        android:id="@+id/tvAge"
        android:layout_width="45dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#1e293b"
        android:gravity="center" />

    <!-- Status Column (width 85dp + margin 16dp to match header) -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="85dp"
        android:layout_height="28dp"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:layout_marginEnd="16dp" />

    <!-- Doctor Column (weight 1.2 to match header) -->
    <TextView
        android:id="@+id/tvDoctor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#360185"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Wait Time Column (width 50dp to match header) -->
    <TextView
        android:id="@+id/tvArrivalTime"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#6b7280"
        android:gravity="end" />

    <!-- DELETE Button -->
    <ImageView
        android:id="@+id/btnDelete"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/delete_icon"
        android:padding="6dp"
        android:layout_marginStart="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless" />

</LinearLayout>